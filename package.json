{
	"name": "macbook-landing",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "npm run type-check && next build",
		"start": "next start",
		"lint": "eslint",
		"type-check": "tsc --noEmit",
		"format": "prettier --write .",
		"analyze": "cross-env ANALYZE=true next build",
		"prepare": "husky"
	},
	"dependencies": {
		"@gsap/react": "2.1.2",
		"@react-three/drei": "10.7.7",
		"@react-three/fiber": "9.5.0",
		"@types/three": "0.183.1",
		"clsx": "2.1.1",
		"critters": "0.0.23",
		"gsap": "3.14.2",
		"lenis": "1.3.21",
		"next": "16.2.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-responsive": "10.0.1",
		"three": "0.183.2",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@builder.io/partytown": "0.10.3",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"cross-env": "10.1.0",
		"cspell": "^10.0.0",
		"eslint": "^9",
		"eslint-config-next": "16.2.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "3.8.2",
		"tailwindcss": "^4",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,ts,tsx}": [
			"eslint --fix",
			"prettier --write",
			"cspell"
		],
		"*.{json,md,css}": [
			"prettier --write"
		]
	}
}
